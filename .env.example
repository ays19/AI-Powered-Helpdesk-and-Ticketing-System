# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/helpdesk?schema=public"

# Better Auth Configuration
BETTER_AUTH_SECRET="your-secret-key-min-32-chars"
BETTER_AUTH_URL="http://localhost:4000"

# Frontend URL — used for CORS and Better Auth trusted origins
TRUSTED_ORIGINS  ="http://localhost:5173"

WEBHOOK_SECRET="" # Required for inbound email webhook

# Seed Admin Credentials
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="password123"

# Groq API Key for AI reply polishing (retrieve from: https://console.groq.com/)
GROQ_API_KEY=""

# Resend API Key for outbound emails (retrieve from: https://resend.com/)
RESEND_API_KEY=""

# Sentry — error monitoring (retrieve DSN from: https://sentry.io/)
# Backend (Node/Express)
SENTRY_DSN=""
# Frontend (React/Vite) — must be prefixed with VITE_ to be exposed to the browser
VITE_SENTRY_DSN=""
# Auth token for uploading source maps during CI/production builds
# Retrieve from: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=""
# Your Sentry organisation slug and project slug (shown in the Sentry project URL)
SENTRY_ORG=""
SENTRY_PROJECT=""