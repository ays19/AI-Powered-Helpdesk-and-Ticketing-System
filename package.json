{
  "name": "helpdesk-ticketing-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "core"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "dev:client": "cd client && bun run dev",
    "dev:all": "bun run dev & bun run dev:client",
    "build:client": "cd client && bun run build",
    "start": "bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:seed": "bun run prisma/src/seed.ts",
    "test:db:setup": "bun --env-file=.env.test run prisma migrate reset --force && bun --env-file=.env.test run prisma/src/seed.ts",
    "test:e2e": "bun run test:db:setup && playwright test",
    "test:e2e:ui": "bun run test:db:setup && playwright test --ui",
    "test:e2e:debug": "bun run test:db:setup && playwright test --debug"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.15",
    "core": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@playwright/test": "^1.60.0",
    "@tanstack/react-query": "^5.101.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "axios": "^1.17.0",
    "prisma": "^7.8.0",
    "react": "^18.3.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
