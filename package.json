{
  "name": "helpdesk-ticketing-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "dev:client": "cd client && bun run dev",
    "dev:all": "bun run dev & bun run dev:client",
    "build:client": "cd client && bun run build",
    "start": "bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:seed": "bun run prisma/src/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.15",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.2",
    "prisma": "^7.8.0",
    "typescript": "^5.7.0"
  }
}
